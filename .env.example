# ── Required ──────────────────────────────────────────────────────────────────

# Hetzner MySQL connection string
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Anthropic API key (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Strong random secret for session JWTs  →  openssl rand -base64 32
JWT_SECRET=

# Admin panel credentials  (replaces the old hardcoded liam / liam1234)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Optional: Hetzner Object Storage (S3-compatible) ─────────────────────────
# Only needed if you use the ingredient photo scanner feature

S3_ENDPOINT=https://YOUR-BUCKET.fsn1.your-objectstorage.com
S3_BUCKET=cocktailored
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central

# ── Local dev only ────────────────────────────────────────────────────────────
NODE_ENV=development
