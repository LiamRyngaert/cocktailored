# ── Required ──────────────────────────────────────────────────────────────────

# MySQL connection string. REQUIRED in production — without it the app falls
# back to non-durable in-memory storage that loses orders on Vercel (each
# serverless instance has its own memory). For high concurrency use a
# serverless MySQL (PlanetScale) or a connection pooler. See docs/RELIABILITY.md.
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Optional: max DB connections PER serverless instance (default 8). Total load
# on the database = number of live instances x this value — keep it modest so a
# traffic burst never exceeds the database's own connection limit.
DB_POOL_SIZE=8

# Optional reliability tunables (sensible defaults shown):
DB_QUERY_TIMEOUT_MS=8000   # time-box every DB query
LLM_TIMEOUT_MS=45000       # time-box each Claude call
LLM_MAX_RETRIES=2          # auto-retry Claude on 429/5xx/network

# Anthropic API key (claude.ai → API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Strong random secret for session JWTs  →  openssl rand -base64 32
JWT_SECRET=

# Admin panel credentials (set via Vercel env vars — never commit real values)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Optional: Hetzner Object Storage (S3-compatible) ─────────────────────────
# Only needed if you use the ingredient photo scanner feature

S3_ENDPOINT=https://YOUR-BUCKET.fsn1.your-objectstorage.com
S3_BUCKET=cocktailored
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central

# ── Local dev only ────────────────────────────────────────────────────────────
NODE_ENV=development
